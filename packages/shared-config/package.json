{
    "name": "@splits-network/shared-config",
    "version": "0.1.0",
    "private": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./src/crypto": {
            "types": "./dist/crypto.d.ts",
            "default": "./dist/crypto.js"
        },
        "./src/vault": {
            "types": "./dist/vault.d.ts",
            "default": "./dist/vault.js"
        },
        "./src/vault-server": {
            "types": "./dist/vault-server.d.ts",
            "default": "./dist/vault-server.js"
        }
    },
    "scripts": {
        "build": "tsc -b",
        "clean": "rm -rf dist *.tsbuildinfo",
        "dev": "tsc -b --watch"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.47.10",
        "dotenv": "^16.4.7",
        "server-only": "^0.0.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.2",
        "typescript": "^5.7.2"
    }
}