# ==============================================================================
# Splits Network -- Staging Environment Configuration
#
# Sourced by deployment and scheduler scripts when ENV=staging.
# All Cloud Run services, Cloud Scheduler jobs, and build steps use these values.
# ==============================================================================

# ------------------------------------------------------------------------------
# GCP Project and Region
# ------------------------------------------------------------------------------
GCP_PROJECT=splits-network-staging
GCP_REGION=us-central1

# ------------------------------------------------------------------------------
# Artifact Registry
# ------------------------------------------------------------------------------
ARTIFACT_REGISTRY=us-central1-docker.pkg.dev/splits-network-staging/splits-network
IMAGE_TAG=staging-latest

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
VPC_CONNECTOR=splits-connector

# ------------------------------------------------------------------------------
# Cloud Scheduler service account
# Must have roles/run.invoker on all target Cloud Run services.
# ------------------------------------------------------------------------------
SCHEDULER_SA=scheduler-invoker@splits-network-staging.iam.gserviceaccount.com

# ------------------------------------------------------------------------------
# Domain URLs
# ------------------------------------------------------------------------------
API_BASE_URL=https://api.staging.splits.network
PORTAL_URL=https://staging.splits.network
CANDIDATE_URL=https://staging.applicant.network
CORPORATE_URL=https://staging.employment-networks.com
STATUS_URL=https://staging.status.splits.network
ADMIN_GATEWAY_URL=https://admin.api.staging.employment-networks.com
LIVEKIT_URL=wss://your-project.livekit.cloud

# ------------------------------------------------------------------------------
# CORS -- allowed origins for API responses
# ------------------------------------------------------------------------------
CORS_ORIGIN=https://staging.splits.network,https://staging.applicant.network,https://staging.employment-networks.com,https://video.staging.splits.network,https://video.staging.applicant.network

# ------------------------------------------------------------------------------
# Frontend build args (NEXT_PUBLIC_* injected at Docker build time)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.staging.splits.network/api
NEXT_PUBLIC_API_GATEWAY_URL=https://api.staging.splits.network
NEXT_PUBLIC_CHAT_GATEWAY_URL=wss://api.staging.splits.network/ws/chat
NEXT_PUBLIC_ANALYTICS_GATEWAY_URL=wss://api.staging.splits.network/ws/analytics
NEXT_PUBLIC_SUPPORT_GATEWAY_URL=wss://api.staging.splits.network/ws/support
NEXT_PUBLIC_CANDIDATE_APP_URL=https://staging.applicant.network
NEXT_PUBLIC_VIDEO_APP_URL=https://video.staging.splits.network
NEXT_PUBLIC_ADMIN_GATEWAY_URL=https://admin.api.staging.employment-networks.com

# ------------------------------------------------------------------------------
# Email
# ------------------------------------------------------------------------------
FROM_EMAIL=noreply@splits.network
RESEND_CANDIDATE_FROM_EMAIL=noreply@applicant.network

# ------------------------------------------------------------------------------
# Scaling -- fewer resources for staging
# ------------------------------------------------------------------------------
DEFAULT_MIN_INSTANCES=0
DEFAULT_MAX_INSTANCES=2
