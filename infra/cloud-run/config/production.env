# ==============================================================================
# Splits Network -- Production Environment Configuration
#
# Sourced by deployment and scheduler scripts when ENV=production.
# All Cloud Run services, Cloud Scheduler jobs, and build steps use these values.
# ==============================================================================

# ------------------------------------------------------------------------------
# GCP Project and Region
# ------------------------------------------------------------------------------
GCP_PROJECT=splits-network-prod
GCP_REGION=us-central1

# ------------------------------------------------------------------------------
# Artifact Registry
# ------------------------------------------------------------------------------
ARTIFACT_REGISTRY=us-central1-docker.pkg.dev/splits-network-prod/splits-network
IMAGE_TAG=latest

# ------------------------------------------------------------------------------
# Networking
# ------------------------------------------------------------------------------
VPC_CONNECTOR=splits-connector

# ------------------------------------------------------------------------------
# Cloud Scheduler service account
# Must have roles/run.invoker on all target Cloud Run services.
# ------------------------------------------------------------------------------
SCHEDULER_SA=scheduler-invoker@splits-network-prod.iam.gserviceaccount.com

# ------------------------------------------------------------------------------
# Domain URLs
# ------------------------------------------------------------------------------
API_BASE_URL=https://api.splits.network
PORTAL_URL=https://splits.network
CANDIDATE_URL=https://applicant.network
CORPORATE_URL=https://employment-networks.com
STATUS_URL=https://status.splits.network
ADMIN_GATEWAY_URL=https://admin.api.employment-networks.com
LIVEKIT_URL=wss://your-project.livekit.cloud

# ------------------------------------------------------------------------------
# CORS -- allowed origins for API responses
# Include both www and non-www variants for production.
# ------------------------------------------------------------------------------
CORS_ORIGIN=https://splits.network,https://www.splits.network,https://applicant.network,https://www.applicant.network,https://employment-networks.com,https://www.employment-networks.com,https://video.splits.network,https://video.applicant.network

# ------------------------------------------------------------------------------
# Frontend build args (NEXT_PUBLIC_* injected at Docker build time)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.splits.network/api
NEXT_PUBLIC_API_GATEWAY_URL=https://api.splits.network
NEXT_PUBLIC_CHAT_GATEWAY_URL=wss://api.splits.network/ws/chat
NEXT_PUBLIC_ANALYTICS_GATEWAY_URL=wss://api.splits.network/ws/analytics
NEXT_PUBLIC_SUPPORT_GATEWAY_URL=wss://api.splits.network/ws/support
NEXT_PUBLIC_CANDIDATE_APP_URL=https://applicant.network
NEXT_PUBLIC_VIDEO_APP_URL=https://video.splits.network
NEXT_PUBLIC_ADMIN_GATEWAY_URL=https://admin.api.employment-networks.com

# ------------------------------------------------------------------------------
# Email
# ------------------------------------------------------------------------------
FROM_EMAIL=noreply@splits.network
RESEND_CANDIDATE_FROM_EMAIL=noreply@applicant.network

# ------------------------------------------------------------------------------
# Scaling -- production needs always-on instances
# ------------------------------------------------------------------------------
DEFAULT_MIN_INSTANCES=1
DEFAULT_MAX_INSTANCES=5
